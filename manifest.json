{
  "manifest_version": 3,
  "name": "HiAnime to AniWatch Redirect",
  "version": "1.0.0",
  "description": "Redirects hianime.to pages to the matching aniwatchtv.to URL.",
  "permissions": [
    "declarativeNetRequest"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "redirect-rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "host_permissions": [
    "*://hianime.to/*",
    "*://www.hianime.to/*"
  ]
}
